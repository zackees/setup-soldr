{
  "name": "setup-soldr",
  "version": "0.1.0",
  "private": true,
  "description": "Setup-soldr GitHub Action: installs soldr, provisions Rust toolchain, manages caches. TypeScript port of the composite action.",
  "main": "dist/main.js",
  "scripts": {
    "build:main": "ncc build src/main.ts -o dist-main --license licenses.txt --no-source-map-register && node scripts/bundle-entrypoint.mjs main",
    "build:post": "ncc build src/post.ts -o dist-post --license licenses.txt --no-source-map-register && node scripts/bundle-entrypoint.mjs post",
    "build": "npm run build:main && npm run build:post",
    "typecheck": "tsc --noEmit",
    "test": "node --test --test-timeout=120000 --experimental-strip-types --import ./__tests__/register-loader.mjs __tests__/log-utils.test.ts __tests__/cache-keys.test.ts __tests__/toolchain.test.ts __tests__/resolve-setup.test.ts __tests__/phase-timing.test.ts __tests__/normalize-source-mtime.test.ts __tests__/detect-shared-target-warning.test.ts __tests__/detect-musl-cc.test.ts __tests__/cache-compress.test.ts __tests__/verify-soldr.test.ts __tests__/ensure-rust-toolchain.test.ts __tests__/ensure-shims.test.ts __tests__/soldr-toolchain-client.test.ts __tests__/ensure-soldr.test.ts __tests__/main.test.ts __tests__/post.test.ts __tests__/compile-cache-stats.test.ts __tests__/dry-run.test.ts __tests__/install-passthrough.test.ts __tests__/shutdown-cache.test.ts __tests__/raw-inputs.test.ts __tests__/diagnostics.test.ts __tests__/source-mtime-snapshot.test.ts __tests__/compile-journal.test.ts __tests__/toolchain-snapshot.test.ts __tests__/solo-toolchain-cache.test.ts __tests__/cook-cache.test.ts __tests__/soldr-mini-cache.test.ts __tests__/shim-bypass-check.test.ts __tests__/cross-bootstrap.test.ts __tests__/watchdog-self-test.test.ts"
  },
  "dependencies": {
    "@actions/artifact": "^2.3.2",
    "@actions/cache": "^4.0.0",
    "@actions/core": "^1.11.1",
    "@actions/exec": "^1.1.1",
    "@actions/io": "^1.1.3",
    "@actions/tool-cache": "^2.0.1",
    "@iarna/toml": "^2.2.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vercel/ncc": "^0.38.4",
    "has-flag": "4.0.0",
    "supports-color": "7.2.0",
    "typescript": "^5.7.0"
  }
}
